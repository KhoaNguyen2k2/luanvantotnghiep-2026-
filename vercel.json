{
    "$schema": "https://openai.vercel.sh/vercel.json",
    "outputDirectory": "public",
    "functions":
    {
        "api/lambda.php": {
            "runtime": "vercel-php@0.6.0"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/lambda.php"
        }
    ]
    
}
